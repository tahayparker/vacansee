generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  // Connection URLs live in prisma.config.ts (migrations) and
  // src/lib/prisma.ts (runtime via driver adapter) as of Prisma 7.
}

model Rooms {
  id        Int    @id @default(autoincrement())
  Name      String
  ShortCode String
  Capacity  Int?

  // Indexes for faster queries
  @@index([ShortCode])
  @@index([Name])
}

model Teacher {
  id    Int    @id @default(autoincrement())
  Name  String
  Email String
  Phone String
}

model Timings {
  id        Int    @id @default(autoincrement())
  SubCode   String
  Class     String
  Day       String
  StartTime String
  EndTime   String
  Room      String
  Teacher   String

  // Composite indexes for common query patterns
  // Used for availability checks by day and time
  @@index([Day, StartTime, EndTime])
  // Used for filtering by specific rooms
  @@index([Room])
  // Used for filtering by day
  @@index([Day])
}

// Vordo: preserved-structure timings — keeps Lecturer/Location ';' separators
// intact, retains the full TypeWithSection (no section stripping), and stores
// the SelectionOption (OR/AND/blank) field that drives vordo's component
// grouping. Populated by upload_raw_timings.py from public/raw_classes.csv.
model RawTimings {
  id              Int    @id @default(autoincrement())
  SubCode         String
  SubName         String
  Type            String
  TypeWithSection String
  TypeFull        String
  // "" (blank) / "OR" / "AND". First row of first component is "".
  // "OR" = alternative within the same component.
  // "AND" = start of a new required component.
  SelectionOption String
  Day             String
  StartTime       String
  EndTime         String
  Location        String
  Lecturer        String
  SemesterId      String

  @@index([SubCode])
  @@index([Day])
}
